n = int(input("Nhập n: "))
x = abs(n)
dem = 0
tong = 0
if x == 0:
    dem = 1
else:
    while x > 0:
        chu_so = x % 10
        tong += chu_so
        dem += 1
        x //= 10
nguyento = True
if n < 2:
    nguyento = False
else:
    for i in range(2, int(n ** 0.5) + 1):
        if n % i == 0:
            nguyento = False
            break
print("Số chữ số:", dem)
print("Tổng chữ số:", tong)
if nguyento:
    print(n, "là số nguyên tố.")
else:
    print(n, "không phải là số nguyên tố.")